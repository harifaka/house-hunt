<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('partials/head') %>
</head>
<body>
<div class="app">
  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <main class="main-content">

    <h1 class="mb-4">⚙️ <%= t.settings %></h1>

    <!-- General Settings -->
    <div class="card mb-6">
      <div class="card__header">
        <h3 class="card__title mb-0"><%= t.settings %></h3>
      </div>
      <div class="card__body">
        <form method="POST" action="/admin/settings">
          <div class="mb-4">
            <label class="form-label" for="language"><%= t.language %></label>
            <select class="form-control" id="language" name="language">
              <option value="hu" <%= (typeof settings !== 'undefined' && settings.language === 'hu') ? 'selected' : '' %>>Magyar (HU)</option>
              <option value="en" <%= (typeof settings !== 'undefined' && settings.language === 'en') ? 'selected' : '' %>>English (EN)</option>
            </select>
          </div>
          <div class="mb-4">
            <label class="form-label" for="app_title"><%= lang === 'en' ? 'App Title' : 'Alkalmazás neve' %></label>
            <input type="text" class="form-control" id="app_title" name="app_title"
                   value="<%= (typeof settings !== 'undefined' && settings.app_title) ? settings.app_title : 'House Hunt Helper' %>">
          </div>
          <button type="submit" class="btn btn-primary"><%= t.save %></button>
        </form>
      </div>
    </div>

    <!-- LLM Configuration -->
    <div class="card mb-6">
      <div class="card__header">
        <h3 class="card__title mb-0">🤖 <%= lang === 'en' ? 'LLM Configuration' : 'LLM konfiguráció' %></h3>
      </div>
      <div class="card__body">
        <form method="POST" action="/admin/ai">
          <div class="mb-4">
            <label class="form-label" for="ai_provider"><%= t.provider %></label>
            <select class="form-control" id="ai_provider" name="ai_provider">
              <option value="ollama" <%= (typeof settings !== 'undefined' && settings.ai_provider === 'ollama') ? 'selected' : '' %>>Ollama</option>
              <option value="openai" <%= (typeof settings !== 'undefined' && settings.ai_provider === 'openai') ? 'selected' : '' %>>OpenAI</option>
              <option value="custom" <%= (typeof settings !== 'undefined' && settings.ai_provider === 'custom') ? 'selected' : '' %>>Custom</option>
            </select>
          </div>
          <div class="mb-4">
            <label class="form-label" for="ai_endpoint"><%= t.endpoint %></label>
            <input type="url" class="form-control" id="ai_endpoint" name="ai_endpoint"
                   value="<%= (typeof settings !== 'undefined' && settings.ai_endpoint) ? settings.ai_endpoint : 'http://localhost:11434' %>"
                   placeholder="http://localhost:11434">
          </div>
          <div class="mb-4">
            <label class="form-label" for="ai_model"><%= t.model %></label>
            <input type="text" class="form-control" id="ai_model" name="ai_model"
                   value="<%= (typeof settings !== 'undefined' && settings.ai_model) ? settings.ai_model : 'llava' %>"
                   placeholder="llava">
          </div>
          <div class="mb-4">
            <label class="form-label" for="ai_api_key"><%= t.api_key %></label>
            <input type="password" class="form-control" id="ai_api_key" name="ai_api_key"
                   value="<%= (typeof settings !== 'undefined' && settings.ai_api_key) ? settings.ai_api_key : '' %>"
                   placeholder="<%= lang === 'en' ? 'Optional — for cloud providers' : 'Opcionális — felhő szolgáltatókhoz' %>">
          </div>
          <div class="d-flex flex-wrap gap-3">
            <button type="submit" class="btn btn-primary"><%= t.save %></button>
            <button type="button" class="btn btn-outline" id="test-connection">
              🔗 <%= lang === 'en' ? 'Test Connection' : 'Kapcsolat tesztelése' %>
            </button>
          </div>
          <div id="test-result" class="mt-3" style="display:none;"></div>
        </form>
      </div>
    </div>

    <!-- Image Storage Configuration -->
    <div class="card mb-6">
      <div class="card__header">
        <h3 class="card__title mb-0">📸 <%= lang === 'en' ? 'Image Storage' : 'Képtárolás' %></h3>
      </div>
      <div class="card__body">
        <form method="POST" action="/admin/image-storage">
          <div class="mb-4">
            <label class="form-label" for="image_storage_provider"><%= lang === 'en' ? 'Storage Provider' : 'Tárolási szolgáltató' %></label>
            <select class="form-control" id="image_storage_provider" name="image_storage_provider">
              <option value="local" <%= (typeof settings !== 'undefined' && settings.image_storage_provider === 'local') || typeof settings === 'undefined' || !settings.image_storage_provider ? 'selected' : '' %>>
                <%= lang === 'en' ? 'Local Storage (default)' : 'Helyi tárolás (alapértelmezett)' %>
              </option>
              <option value="imgbb" <%= (typeof settings !== 'undefined' && settings.image_storage_provider === 'imgbb') ? 'selected' : '' %>>
                imgbb
              </option>
            </select>
            <div class="text-xs text-muted mt-1">
              <%= lang === 'en'
                ? 'Images are stored locally by default. Select imgbb for cloud storage. EXIF/GPS data is stripped before upload.'
                : 'A képek alapértelmezetten helyben tárolódnak. Válaszd az imgbb-t felhő tároláshoz. EXIF/GPS adatok feltöltés előtt eltávolításra kerülnek.' %>
            </div>
          </div>
          <div class="mb-4" id="imgbb-settings" style="display:<%= (typeof settings !== 'undefined' && settings.image_storage_provider === 'imgbb') ? 'block' : 'none' %>;">
            <label class="form-label" for="imgbb_api_key"><%= lang === 'en' ? 'imgbb API Key' : 'imgbb API kulcs' %></label>
            <input type="password" class="form-control" id="imgbb_api_key" name="imgbb_api_key"
                   value="<%= (typeof settings !== 'undefined' && settings.imgbb_api_key) ? settings.imgbb_api_key : '' %>"
                   placeholder="<%= lang === 'en' ? 'Enter your imgbb API key' : 'Add meg az imgbb API kulcsot' %>">
            <div class="text-xs text-muted mt-1">
              <%= lang === 'en' ? 'Get your free API key at https://api.imgbb.com/' : 'Ingyenes API kulcsot a https://api.imgbb.com/ oldalon szerezhetsz.' %>
            </div>
          </div>
          <button type="submit" class="btn btn-primary"><%= t.save %></button>
        </form>
      </div>
    </div>

    <!-- Local Backup / Restore -->
    <div class="card mb-6">
      <div class="card__header">
        <h3 class="card__title mb-0">💾 <%= lang === 'en' ? 'Local Backup' : 'Helyi biztonsági mentés' %></h3>
      </div>
      <div class="card__body">
        <p class="text-xs text-muted mb-4">
          <%= lang === 'en'
            ? 'Export or import your local browser cache. This includes quiz answers, calculator data, and offline backups stored in your browser.'
            : 'Exportáld vagy importáld a helyi böngésző gyorsítótárat. Ez tartalmazza a kérdőív válaszokat, kalkulátor adatokat és az offline biztonsági mentéseket.' %>
        </p>
        <div class="d-flex flex-wrap gap-3">
          <button type="button" class="btn btn-outline" id="backup-export">
            📥 <%= lang === 'en' ? 'Export Backup' : 'Mentés exportálása' %>
          </button>
          <button type="button" class="btn btn-outline" id="backup-import">
            📤 <%= lang === 'en' ? 'Import Backup' : 'Mentés importálása' %>
          </button>
          <button type="button" class="btn btn-outline" id="backup-clear" style="color:var(--danger)">
            🗑️ <%= lang === 'en' ? 'Clear Local Data' : 'Helyi adatok törlése' %>
          </button>
        </div>
        <input type="file" id="backup-file-input" accept=".json" style="display:none;">
        <div id="backup-result" class="mt-3" style="display:none;"></div>
      </div>
    </div>

    <%- include('partials/footer') %>
  </main>
</div>
<%- include('partials/scripts') %>
<script>
document.getElementById('test-connection').addEventListener('click', function() {
  var endpoint = document.getElementById('ai_endpoint').value;
  var resultEl = document.getElementById('test-result');
  resultEl.style.display = 'block';
  resultEl.innerHTML = '<span class="text-muted"><%= lang === "en" ? "Testing connection..." : "Kapcsolat tesztelése..." %></span>';

  fetch(endpoint)
    .then(function(r) {
      if (r.ok) {
        resultEl.innerHTML = '<span style="color:var(--success)">✅ <%= lang === "en" ? "Connection successful!" : "Sikeres kapcsolat!" %></span>';
      } else {
        resultEl.innerHTML = '<span style="color:var(--danger)">❌ <%= lang === "en" ? "Connection failed (HTTP " : "Kapcsolat sikertelen (HTTP " %>' + r.status + ')</span>';
      }
    })
    .catch(function() {
      resultEl.innerHTML = '<span style="color:var(--danger)">❌ <%= lang === "en" ? "Connection failed — endpoint unreachable" : "Kapcsolat sikertelen — végpont nem elérhető" %></span>';
    });
});

// Toggle imgbb settings visibility
document.getElementById('image_storage_provider').addEventListener('change', function() {
  document.getElementById('imgbb-settings').style.display = this.value === 'imgbb' ? 'block' : 'none';
});

// Backup export
document.getElementById('backup-export').addEventListener('click', function() {
  if (!window.HouseHuntBackup) return;
  var data = window.HouseHuntBackup.exportAllData();
  var blob = new Blob([data], { type: 'application/json' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'house-hunt-backup-' + new Date().toISOString().slice(0, 10) + '.json';
  a.click();
  URL.revokeObjectURL(url);
  var el = document.getElementById('backup-result');
  el.style.display = 'block';
  el.innerHTML = '<span style="color:var(--success)">✅ <%= lang === "en" ? "Backup exported successfully" : "Mentés sikeresen exportálva" %></span>';
});

// Backup import
document.getElementById('backup-import').addEventListener('click', function() {
  document.getElementById('backup-file-input').click();
});
document.getElementById('backup-file-input').addEventListener('change', function(e) {
  var file = e.target.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var el = document.getElementById('backup-result');
    el.style.display = 'block';
    if (window.HouseHuntBackup && window.HouseHuntBackup.importAllData(ev.target.result)) {
      el.innerHTML = '<span style="color:var(--success)">✅ <%= lang === "en" ? "Backup imported successfully" : "Mentés sikeresen importálva" %></span>';
    } else {
      el.innerHTML = '<span style="color:var(--danger)">❌ <%= lang === "en" ? "Failed to import backup" : "Nem sikerült importálni a mentést" %></span>';
    }
  };
  reader.readAsText(file);
});

// Backup clear
document.getElementById('backup-clear').addEventListener('click', function() {
  if (!confirm('<%= lang === "en" ? "Are you sure you want to clear all local backup data?" : "Biztosan törölni akarod az összes helyi biztonsági mentést?" %>')) return;
  if (window.HouseHuntBackup) window.HouseHuntBackup.clearAllData();
  var el = document.getElementById('backup-result');
  el.style.display = 'block';
  el.innerHTML = '<span style="color:var(--success)">✅ <%= lang === "en" ? "Local data cleared" : "Helyi adatok törölve" %></span>';
});
</script>
</body>
</html>
