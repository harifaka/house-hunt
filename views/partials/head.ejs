<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="<%= t.tagline %>">
<title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %><%= t.app_title %></title>
<link rel="icon" href="/favicon.ico" type="image/x-icon">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<script>
// Apply theme before paint to prevent FOUC — default is dark
(function(){var c=document.cookie.match(/(?:^|; )theme=(dark|light)/);var t=c?c[1]:'dark';document.documentElement.setAttribute('data-theme',t);})();
</script>
